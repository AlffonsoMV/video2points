\@writefile{toc}{\contentsline {section}{\numberline {3}Generator Comparison}{2}{section.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.1}Plant}{2}{subsection.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Plant comparison over four iterations. Each row corresponds to one iteration. For each generator we show the target sparse render requested by the planner, the generated image, and the rerender obtained after reconstruction with the new image. Nano Banana is visually cleaner, but the rerender still reveals that geometric improvement remains limited.}}{3}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:plant-grid}{{1}{3}{Plant comparison over four iterations. Each row corresponds to one iteration. For each generator we show the target sparse render requested by the planner, the generated image, and the rerender obtained after reconstruction with the new image. Nano Banana is visually cleaner, but the rerender still reveals that geometric improvement remains limited}{figure.caption.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}Colosseum}{3}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Colosseum comparison over four iterations. FLUX expands the viewing arc more aggressively, but Nano Banana avoids the most obvious semantic failure mode: generating duplicated landmarks. The rerenders show that neither model is fully reliable once the sparse conditioning becomes weak.}}{4}{figure.caption.2}\protected@file@percent }
\newlabel{fig:colosseum-grid}{{2}{4}{Colosseum comparison over four iterations. FLUX expands the viewing arc more aggressively, but Nano Banana avoids the most obvious semantic failure mode: generating duplicated landmarks. The rerenders show that neither model is fully reliable once the sparse conditioning becomes weak}{figure.caption.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3}Pyramid of Giza}{4}{subsection.3.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Pyramid comparison. The prompts explicitly describe the structure as the intact Great Pyramid of Giza rather than a broken ruin. This improves the generated imagery, but the rerenders remain weak, indicating that the geometry is still not being recovered reliably. Nano Banana completed three iterations in this run.}}{5}{figure.caption.3}\protected@file@percent }
\newlabel{fig:pyramid-grid}{{3}{5}{Pyramid comparison. The prompts explicitly describe the structure as the intact Great Pyramid of Giza rather than a broken ruin. This improves the generated imagery, but the rerenders remain weak, indicating that the geometry is still not being recovered reliably. Nano Banana completed three iterations in this run}{figure.caption.3}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4}Generator Fidelity Across Working Scenes}{5}{subsection.3.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Fidelity on pixels already supported by the sparse target render, measured only with MAE. Left: target sparse render versus generated image, which directly evaluates the generator. Right: target sparse render versus rerender after reconstruction, which evaluates how much of that structure survives VGGT. Lower is better. Nano Banana dominates the generator metric on all scenes and also wins on average in the rerender metric, despite Plant being a small exception.}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:avg-metrics}{{4}{6}{Fidelity on pixels already supported by the sparse target render, measured only with MAE. Left: target sparse render versus generated image, which directly evaluates the generator. Right: target sparse render versus rerender after reconstruction, which evaluates how much of that structure survives VGGT. Lower is better. Nano Banana dominates the generator metric on all scenes and also wins on average in the rerender metric, despite Plant being a small exception}{figure.caption.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Per-scene MAE summary. The first pair of columns evaluates the generator directly. The second pair evaluates the full loop after reconstruction. Nano Banana wins on every scene for target-to-generated fidelity and on average for target-to-rerender fidelity.}}{6}{table.caption.5}\protected@file@percent }
\newlabel{tab:scene-summary}{{1}{6}{Per-scene MAE summary. The first pair of columns evaluates the generator directly. The second pair evaluates the full loop after reconstruction. Nano Banana wins on every scene for target-to-generated fidelity and on average for target-to-rerender fidelity}{table.caption.5}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Limitations and Practical Findings}{6}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Object-Only Scenes Without Background}{6}{subsection.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Chair limitation case. For both generators, the target sparse render and final rerender remain poor even when the generated image itself is plausible. This supports the conclusion that background-poor single-object inputs are a poor match for a scene-centric reconstructor such as VGGT.}}{7}{figure.caption.6}\protected@file@percent }
\newlabel{fig:chair-limit}{{5}{7}{Chair limitation case. For both generators, the target sparse render and final rerender remain poor even when the generated image itself is plausible. This supports the conclusion that background-poor single-object inputs are a poor match for a scene-centric reconstructor such as VGGT}{figure.caption.6}{}}
