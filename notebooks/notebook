 "cells": [
  {
   "cell_type": "markdown",
   "id": "25afb55f",
   "metadata": {},
   "source": [
    "# VGGT + Novel View Inpainting Pipeline (Coliseum)\n",
    "\n",
    "This notebook runs a complete pipeline:\n",
    "\n",
    "1. Imports and setup\n",
    "2. Parameters / config\n",
    "3. Load and run **VGGT**\n",
    "4. Reconstruct and plot a 3D point cloud from `data/image_01.*`\n",
    "5. Reproject the 3D model from the recovered camera and from a shifted camera\n",
    "6. Build a hole mask from the shifted-camera projection\n",
    "7. Inpaint the holes with a diffusion inpainting model (Mac-compatible via Diffusers)\n",
    "8. Run VGGT again with the original + inpainted novel view and show the new 3D model\n",
    "\n",
    "The heavy lifting is in `utils.py` (already smoke-tested before this notebook was generated).\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "86da77e5",
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import json\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "from IPython.display import display\n",
    "\n",
    "import utils\n",
    "\n",
    "plt.rcParams['figure.dpi'] = 120\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5e08064c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Parameters / config\n",
    "cfg = utils.PipelineConfig(\n",
    "    data_dir='data',\n",
    "    output_dir='outputs/notebook_run',\n",
    "    input_image_stem='image_01',\n",
    "    preprocess_mode='crop',\n",
    "    vggt_conf_percentile=55.0,\n",
    "    max_points_plot=30000,\n",
    "    max_points_render=150000,\n",
    "    render_point_radius=1,\n",
    "    novel_shift_right=0.18,\n",
    "    novel_yaw_deg=-7.0,\n",
    "    novel_pitch_deg=0.0,\n",
    "    novel_roll_deg=0.0,\n",
    "    mask_dilate_px=4,\n",
    "    mask_close_px=3,\n",
    "    inpaint_steps=20,\n",
    "    inpaint_guidance_scale=6.5,\n",
    "    seed=0,\n",
    ")\n",
    "\n",
    "utils.seed_everything(cfg.seed)\n",
    "device = utils.get_device()\n",
    "out_dir = utils.ensure_dir(cfg.output_dir)\n",
    "print('Device:', device)\n",
    "print('Output dir:', Path(out_dir).resolve())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5f0f2112",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Resolve input image from /data and ensure a PNG copy for convenience\n",
    "input_image_path = utils.resolve_input_image(cfg.data_dir, cfg.input_image_stem)\n",
    "input_png_path = utils.ensure_png_copy(input_image_path)\n",
    "original_image = Image.open(input_png_path).convert('RGB')\n",
    "\n",
    "print('Input image found:', input_image_path)\n",
    "print('PNG path used in notebook:', input_png_path)\n",
    "display(original_image)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "92a5c7c8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3) Download + run VGGT on the original image\n",
    "model = utils.load_vggt_model(cfg.vggt_model_id, device=device)\n",
    "scene1 = utils.run_vggt_reconstruction(\n",
    "    [input_png_path],\n",
    "    model=model,\n",
    "    device=device,\n",
    "    preprocess_mode=cfg.preprocess_mode,\n",
    "    model_id=cfg.vggt_model_id,\n",
    ")\n",
    "\n",
    "print(json.dumps(utils.describe_scene(scene1), indent=2, default=str))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f289edff",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4) Plot the 3D model (point cloud) reconstructed by VGGT\n",
    "pts1, cols1, conf1 = utils.build_point_cloud_from_scene(\n",
    "    scene1,\n",
    "    view_idx=0,\n",
    "    prefer_depth_unprojection=True,\n",
    "    conf_percentile=cfg.vggt_conf_percentile,\n",
    "    max_points=cfg.max_points_plot,\n",
    ")\n",
    "print('Selected points for plotting:', len(pts1))\n",
    "\n",
    "fig, ax = utils.plot_point_cloud_3d(\n",
    "    pts1,\n",
    "    cols1,\n",
    "    title='Single-view VGGT 3D Reconstruction',\n",
    "    point_size=0.25,\n",
    ")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "39c2ed7d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4) Project the 3D model from the camera estimated by VGGT\n",
    "base_render = utils.render_scene_view(\n",
    "    scene1,\n",
    "    view_idx=0,\n",
    "    conf_percentile=cfg.vggt_conf_percentile,\n",
    "    max_points=cfg.max_points_render,\n",
    "    point_radius=cfg.render_point_radius,\n",
    "    prefer_depth_unprojection=True,\n",
    ")\n",
    "\n",
    "preprocessed_input = Image.fromarray((np.clip(scene1['images_nhwc'][0], 0, 1) * 255).astype(np.uint8))\n",
    "fig, axes = utils.plot_image_grid(\n",
    "    [preprocessed_input, base_render.image],\n",
    "    titles=['VGGT preprocessed input', '3D point cloud projected from VGGT camera'],\n",
    "    figsize=(12, 4),\n",
    ")\n",
    "plt.show()\n",
    "\n",
    "print('Base projection valid ratio:', float(base_render.valid_mask.mean()))\n",
    "print('Projected pixels:', base_render.projected_count)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "073d1986",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5) Move the camera a bit to the right (+ rotation), project into 2D, and show the result\n",
    "novel_render, novel_extr, novel_intr = utils.build_novel_view_render(\n",
    "    scene1,\n",
    "    base_view_idx=0,\n",
    "    shift_right=cfg.novel_shift_right,\n",
    "    yaw_deg=cfg.novel_yaw_deg,\n",
    "    pitch_deg=cfg.novel_pitch_deg,\n",
    "    roll_deg=cfg.novel_roll_deg,\n",
    "    conf_percentile=cfg.vggt_conf_percentile,\n",
    "    max_points=cfg.max_points_render,\n",
    "    point_radius=cfg.render_point_radius,\n",
    ")\n",
    "\n",
    "fig, axes = utils.plot_image_grid(\n",
    "    [base_render.image, novel_render.image],\n",
    "    titles=['Projection from original camera', 'Projection from shifted/rotated camera'],\n",
    "    figsize=(12, 4),\n",
    ")\n",
    "plt.show()\n",
    "\n",
    "print('Novel projection valid ratio:', float(novel_render.valid_mask.mean()))\n",
    "print('Projected pixels:', novel_render.projected_count)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "96235293",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 6) Build a hole mask (regions not covered by the projected point cloud)\n",
    "novel_img, hole_mask, hole_overlay = utils.prepare_novel_view_inpainting_inputs(\n",
    "    novel_render,\n",
    "    dilate_px=cfg.mask_dilate_px,\n",
    "    close_px=cfg.mask_close_px,\n",
    ")\n",
    "\n",
    "hole_mask_ratio = float((np.asarray(hole_mask) > 0).mean())\n",
    "print('Hole mask ratio:', hole_mask_ratio)\n",
    "\n",
    "fig, axes = utils.plot_image_grid(\n",
    "    [novel_img, hole_overlay, hole_mask.convert('RGB')],\n",
    "    titles=['Novel-view projection', 'Hole mask overlay', 'Hole mask'],\n",
    "    figsize=(15, 4),\n",
    ")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f317a389",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 7) Diffusion inpainting (preserve unmasked pixels exactly)\n",
    "# Free VGGT weights before loading the inpainting pipeline to reduce memory pressure on Mac/MPS.\n",
    "del model\n",
    "utils.clear_loaded_model_caches()\n",
    "\n",
    "inpaint_prompt = (\n",
    "    'Photorealistic continuation of the Roman Colosseum scene from a slightly shifted viewpoint, '\n",
    "    'fill only the missing regions while preserving visible content, lighting, and stone texture.'\n",
    ")\n",
    "\n",
    "inpaint_result = utils.inpaint_with_diffusion(\n",
    "    image=novel_img,\n",
    "    mask=hole_mask,\n",
    "    prompt=inpaint_prompt,\n",
    "    model_id=cfg.inpaint_model_id,\n",
    "    device=device,\n",
    "    num_inference_steps=cfg.inpaint_steps,\n",
    "    guidance_scale=cfg.inpaint_guidance_scale,\n",
    "    seed=cfg.seed,\n",
    "    allow_fallback_to_opencv=True,\n",
    ")\n",
    "\n",
    "# Verify that pixels outside the mask were not changed by the final compositing step\n",
    "orig_np = np.asarray(novel_img.convert('RGB'))\n",
    "comp_np = np.asarray(inpaint_result.composited.convert('RGB'))\n",
    "mask_np = np.asarray(hole_mask.convert('L')) > 0\n",
    "changed_outside_mask = int(np.any(orig_np != comp_np, axis=-1)[~mask_np].sum())\n",
    "\n",
    "print('Inpainting backend:', inpaint_result.backend)\n",
    "print('Resized for model:', inpaint_result.resized_for_model)\n",
    "print('Changed pixels outside mask (should be 0):', changed_outside_mask)\n",
    "\n",
    "fig, axes = utils.plot_image_grid(\n",
    "    [novel_img, inpaint_result.composited],\n",
    "    titles=['Novel-view projection (with holes)', 'Inpainted novel view'],\n",
    "    figsize=(12, 4),\n",
    ")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "330939cf",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Save intermediate images (useful for debugging / reruns)\n",
    "inpainted_path = Path(out_dir) / 'novel_view_inpainted.png'\n",
    "mask_path = Path(out_dir) / 'novel_view_hole_mask.png'\n",
    "novel_path = Path(out_dir) / 'novel_view_projection.png'\n",
    "\n",
    "utils.save_pil(inpaint_result.composited, inpainted_path)\n",
    "utils.save_pil(hole_mask, mask_path)\n",
    "utils.save_pil(novel_img, novel_path)\n",
    "\n",
    "print('Saved:')\n",
    "print(' -', inpainted_path.resolve())\n",
    "print(' -', mask_path.resolve())\n",
    "print(' -', novel_path.resolve())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "23938364",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 8) Run VGGT with the original image + inpainted novel view, then show the new 3D model\n",
    "utils.clear_loaded_model_caches()\n",
    "model2 = utils.load_vggt_model(cfg.vggt_model_id, device=device)\n",
    "scene2 = utils.build_two_view_reconstruction(\n",
    "    original_image_path=input_png_path,\n",
    "    novel_inpainted_image_path=inpainted_path,\n",
    "    model=model2,\n",
    "    device=device,\n",
    "    preprocess_mode=cfg.preprocess_mode,\n",
    "    model_id=cfg.vggt_model_id,\n",
    ")\n",
    "\n",
    "print(json.dumps(utils.describe_scene(scene2), indent=2, default=str))\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "48dab51b",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot the new two-view 3D model\n",
    "pts2, cols2, conf2 = utils.build_point_cloud_from_scene(\n",
    "    scene2,\n",
    "    view_idx=0,\n",
    "    prefer_depth_unprojection=True,\n",
    "    conf_percentile=cfg.vggt_conf_percentile,\n",
    "    max_points=cfg.max_points_plot,\n",
    ")\n",
    "print('Selected points for plotting (2-view):', len(pts2))\n",
    "\n",
    "fig, ax = utils.plot_point_cloud_3d(\n",
    "    pts2,\n",
    "    cols2,\n",
    "    title='Two-view VGGT Reconstruction (original + inpainted novel view)',\n",
    "    point_size=0.25,\n",
    ")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "71ad1194",
   "metadata": {},
   "source": [
    "## Notes\n",
    "\n",
    "- `utils.py` was smoke-tested before generating this notebook (synthetic geometry test + full end-to-end test on the Coliseum image).\n",
    "- On Mac, diffusion inpainting is run with a robust wrapper that prefers MPS but retries safely if the output is degenerate.\n",
    "- VGGT outputs can vary slightly across devices/dtypes, but shapes and the pipeline structure should remain stable.\n"
   ]
  }
